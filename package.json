{
  "name": "micro-fuzzy",
  "version": "1.1.0",
  "description": "A sub-2kb, typo-tolerant fuzzy search library",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikocoral05/micro-fuzzy.git"
  },
  "main": "./dist/micro-fuzzy.umd.cjs",
  "module": "./dist/micro-fuzzy.js",
  "types": "./src/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./dist/micro-fuzzy.js",
      "require": "./dist/micro-fuzzy.umd.cjs"
    }
  },
  "files": [
    "dist",
    "src/index.d.ts"
  ],
  "funding": [
    {
      "type": "ko-fi",
      "url": "https://ko-fi.com/mikaeltenshio"
    },
    {
      "type": "buymeacoffee",
      "url": "https://buymeacoffee.com/mikaeltenshio"
    }
  ],
  "scripts": {
    "test": "vitest run",
    "build": "vite build",
    "precompat": "npm run build",
    "compat": "node scripts/check-compat.mjs",
    "prebench": "npm run build",
    "bench": "node scripts/bench.mjs"
  },
  "devDependencies": {
    "vitest": "^1.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "semantic-release": "^25.0.3",
    "vite": "^7.1.7"
  },
  "publishConfig": {
    "access": "public"
  }
}
